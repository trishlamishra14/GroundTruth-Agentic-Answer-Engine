# Copy to ".env" and fill in. NEVER commit the real .env.

# Free Cohere trial key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-trial-key

# Models (free trial tier)
EMBEDDING_MODEL=embed-english-v3.0
CHAT_MODEL=command-r-08-2024
RERANK_MODEL=rerank-v3.5
EMBEDDING_DIM=1024

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://rag:rag@localhost:5432/ragdb

# Agent behaviour
ABSTAIN_THRESHOLD=0.20
MAX_AGENT_LOOPS=2
USE_LANGGRAPH=false
